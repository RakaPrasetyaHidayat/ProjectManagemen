{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/app.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "npx tsx --watch app.ts",
    "build": "npx prisma generate && npx tsc && cp -r generated dist/ && npm run type-check",
    "vercel-build": "npx prisma generate && npx tsc --noEmit",
    "start": "node dist/app.js",
    "start:dev": "npx tsx app.ts",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "type-check": "npx tsc --noEmit",
    "lint": "npx eslint .",
    "test:api": "npx tsx check-db.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/express-rate-limit": "^5.1.3",
    "bcrypt": "^5.0.0",
    "compression": "^1.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemon": "^3.1.14",
    "pg": "^8.11.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^7.0.0"
  }
}
